APP_NAME=Prompt2App Studio API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# JSON array string for CORS origins.
CORS_ORIGINS=["http://localhost:5173"]

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/prompt2app

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
